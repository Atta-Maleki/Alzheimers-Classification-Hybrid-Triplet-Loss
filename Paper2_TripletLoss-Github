 test images. These embeddings capture the learned representations from the triplet loss optimization. A simple dense neural network classifier is then defined and trained on these embeddings to perform the final binary classification task (Non-Demented vs. Very Mild Dementia)."]},{"cell_type":"code","source":["# Extract the base network from the triplet model\n","embedding_model = tf.keras.models.Model(inputs=triplet_model.input[0], outputs=triplet_model.layers[-4].output)  # Adjust this if the layer index is different\n","\n","# Generate embeddings for training and test images\n","train_embeddings = embedding_model.predict(trainImages)\n","test_embeddings = embedding_model.predict(testImages)\n","\n","trainLabels = np.argmax(trainLabels, axis=1)\n","testLabels = np.argmax(testLabels, axis=1)\n","# Sanity check for NaN or Inf values in the embeddings\n","assert not np.any(np.isnan(train_embeddings)), \"train_embeddings contains NaN values\"\n","assert not np.any(np.isinf(train_embeddings)), \"train_embeddings contains Inf values\"\n","assert not np.any(np.isnan(test_embeddings)), \"test_embeddings contains NaN values\"\n","assert not np.any(np.isinf(test_embeddings)), \"test_embeddings contains Inf values\"\n","\n","print(\"Embeddings generated successfully.\")\n","from sklearn.linear_model import LogisticRegression\n","from sklearn.metrics import classification_report, accuracy_score\n","\n","from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import Dense\n","\n","# Define a simple neural network classifier\n","classifier = Sequential([\n","    Dense(128, activation='relu', input_shape=(train_embeddings.shape[1],)),\n","    Dense(64, activation='relu'),\n","    Dense(1, activation='sigmoid')\n","])\n","\n","classifier.compile(optimizer='adam', loss='binary_crossentropy',\n","                   metrics=['accuracy'])\n","\n","# Train the classifier\n","hist2 = classifier.fit(train_embeddings, trainLabels, epochs=10, batch_size=32,\n","  